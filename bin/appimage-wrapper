#!/usr/bin/env bash
set -euo pipefail

usage() {
  printf 'Usage: %s [--cleanup-old] [--flags-file <file>] [--no-flags] [--env-file <file>] [--no-env] <app-name> [args...]\n' "$(basename "$0")" >&2
}

cleanup_old=false
use_default_flags=true
flags_files=()
use_default_env=true
env_files=()

while [[ $# -gt 0 ]]; do
  case "${1:-}" in
    --cleanup-old)
      cleanup_old=true
      shift
      ;;
    --flags-file)
      flags_files+=("${2:?appimage-wrapper: --flags-file requires a value}")
      use_default_flags=false
      shift 2
      ;;
    --no-flags)
      use_default_flags=false
      flags_files=()
      shift
      ;;
    --env-file)
      env_files+=("${2:?appimage-wrapper: --env-file requires a value}")
      use_default_env=false
      shift 2
      ;;
    --no-env)
      use_default_env=false
      env_files=()
      shift
      ;;
    -h|--help)
      usage
      exit 2
      ;;
    --)
      shift
      break
      ;;
    -*)
      printf 'appimage-wrapper: unknown option: %s\n' "$1" >&2
      usage
      exit 2
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -lt 1 ]]; then
  usage
  exit 2
fi

app_name=$1
shift
config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
flag_args=()
env_args=()

search_dirs=()
seen_dirs=":"
search_label="PATH"

add_search_dir() {
  local dir=$1

  [[ -n "$dir" && -d "$dir" ]] || return 0

  case ":$seen_dirs:" in
    *:"$dir":*) return 0 ;;
  esac

  search_dirs+=("$dir")
  seen_dirs+="$dir:"
}

if [[ "$app_name" == */* || -z "$app_name" ]]; then
  printf 'appimage-wrapper: invalid app name: %s\n' "$app_name" >&2
  exit 2
fi

read_flags_file() {
  local file=$1
  local line

  if [[ ! -f "$file" ]]; then
    return 0
  fi

  while IFS= read -r line || [[ -n "$line" ]]; do
    line=${line%$'\r'}
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    flag_args+=("$line")
  done < "$file"
}

read_env_file() {
  local file=$1
  local line key value

  if [[ ! -f "$file" ]]; then
    return 0
  fi

  while IFS= read -r line || [[ -n "$line" ]]; do
    line=${line%$'\r'}
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    line=${line#"${line%%[![:space:]]*}"}
    if [[ "$line" =~ ^export[[:space:]]+ ]]; then
      line=${line#export}
      line=${line#"${line%%[![:space:]]*}"}
    fi

    if [[ "$line" != *=* ]]; then
      printf 'appimage-wrapper: ignoring invalid env line in %s: %s\n' "$file" "$line" >&2
      continue
    fi

    key=${line%%=*}
    value=${line#*=}
    key=${key%"${key##*[![:space:]]}"}
    value=${value#"${value%%[![:space:]]*}"}
    value=${value%"${value##*[![:space:]]}"}

    if [[ "$value" == \"*\" && "$value" == *\" ]]; then
      value=${value:1:${#value}-2}
    elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
      value=${value:1:${#value}-2}
    fi

    if [[ ! "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
      printf 'appimage-wrapper: ignoring invalid env key in %s: %s\n' "$file" "$key" >&2
      continue
    fi

    env_args+=("$key=$value")
  done < "$file"
}

if [[ "$use_default_flags" == true ]]; then
  flags_files=(
    "$config_home/$app_name-flags.conf"
    "$config_home/$app_name/flags.conf"
    "$config_home/$app_name/user-flags.conf"
  )
fi

if [[ "$use_default_env" == true ]]; then
  env_files=(
    "$config_home/$app_name.env"
    "$config_home/$app_name/.env"
    "$config_home/$app_name/user.env"
  )
fi

for file in "${flags_files[@]}"; do
  read_flags_file "$file"
done

for file in "${env_files[@]}"; do
  read_env_file "$file"
done

if [[ -n "${APPIMAGE_WRAPPER_DIR:-}" ]]; then
  search_label="$APPIMAGE_WRAPPER_DIR"
  add_search_dir "$APPIMAGE_WRAPPER_DIR"
else
  IFS=: read -r -a path_dirs <<< "${PATH:-}"
  for dir in "${path_dirs[@]}"; do
    add_search_dir "$dir"
  done
fi

mapfile -d '' matches < <(
  for dir in "${search_dirs[@]}"; do
    find "$dir" -maxdepth 1 -type f -name "$app_name-*.AppImage" -print0
  done
)

if [[ ${#matches[@]} -eq 0 ]]; then
  printf 'appimage-wrapper: no match for %s-*.AppImage in %s\n' "$app_name" "$search_label" >&2
  exit 1
fi

selected=$(
  for path in "${matches[@]}"; do
    file=${path##*/}
    version=${file#"$app_name-"}
    version=${version%.AppImage}
    printf '%s\t%s\n' "$version" "$path"
  done | sort -t $'\t' -k1,1V | tail -n 1 | cut -f2-
)

if [[ ! -x "$selected" ]]; then
  chmod +x "$selected"
fi

if [[ "$cleanup_old" == true ]]; then
  for path in "${matches[@]}"; do
    [[ "$path" != "$selected" ]] || continue
    rm -f -- "$path"
  done
fi

exec env "${env_args[@]}" "$selected" "${flag_args[@]}" "$@"
